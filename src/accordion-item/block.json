{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "accordion-animated/accordion-item",
	"title": "Accordion Item (Animated)",
	"category": "design",
	"parent": [ "core/accordion" ],
	"description": "Accordion item with InnerBlocks heading support.",
	"textdomain": "accordion-animated",
	"providesContext": {
		"core/accordion-icon-position": "iconPosition",
		"core/accordion-show-icon": "showIcon",
		"core/accordion-heading-level": "headingLevel"
	},
	"attributes": {
		"openByDefault": {
			"type": "boolean",
			"default": false
		}
	},
	"supports": {
		"anchor": true,
		"interactivity": {
			"clientNavigation": true
		},
		"color": {
			"background": true,
			"gradients": true,
			"text": false
		},
		"spacing": {
			"padding": true,
			"margin": true,
			"blockGap": true,
			"__experimentalDefaultControls": {
				"padding": true,
				"blockGap": true
			}
		},
		"__experimentalBorder": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		}
	}
}
